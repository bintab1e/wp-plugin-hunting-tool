{
  "rules": [
    {
      "id": "poc_sqli_concat_exec_1",
      "category": "SQLi",
      "enabled": true,
      "input_pattern": "\\$([A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*(?:sanitize_text_field|sanitize_key|sanitize_textarea_field|wp_unslash)?\\s*\\(?\\s*\\$_(?:GET|POST|REQUEST|COOKIE)\\s*\\[[^\\]]+\\]\\s*\\)?",
      "output_pattern": "\\$wpdb->(?:query|get_results|get_row|get_var|get_col)\\s*\\(\\s*(?!\\$wpdb->prepare\\s*\\()(?:(?:\\\"[^\\\"\\n]*(?:SELECT|INSERT|UPDATE|DELETE)[^\\\"\\n]*\\\"\\s*\\.\\s*\\$\\1)|(?:'[^'\\n]*(?:SELECT|INSERT|UPDATE|DELETE)[^'\\n]*'\\s*\\.\\s*\\$\\1)|(?:\\$\\1\\s*\\.\\s*\\\"[^\\\"\\n]*(?:SELECT|INSERT|UPDATE|DELETE)[^\\\"\\n]*\\\")|(?:\\$\\1\\s*\\.\\s*'[^'\\n]*(?:SELECT|INSERT|UPDATE|DELETE)[^'\\n]*'))"
    },
    {
      "id": "poc_sqli_order_limit_1",
      "category": "SQLi",
      "enabled": true,
      "input_pattern": "\\$([A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*sanitize_text_field\\s*\\(\\s*(?:wp_unslash\\s*\\()?\\s*\\$_(?:GET|POST|REQUEST)\\s*\\[[^\\]]+\\]\\s*\\)?\\s*\\)",
      "output_pattern": "\\$wpdb->(?:query|get_results|get_row|get_var|get_col)\\s*\\(\\s*(?!\\$wpdb->prepare\\s*\\()(?:(?:\\\"[^\\\"\\n]*(?:ORDER\\s+BY|LIMIT)[^\\\"\\n]*\\\"\\s*\\.\\s*\\$\\1)|(?:'[^'\\n]*(?:ORDER\\s+BY|LIMIT)[^'\\n]*'\\s*\\.\\s*\\$\\1)|(?:\\$\\1\\s*\\.\\s*\\\"[^\\\"\\n]*(?:ORDER\\s+BY|LIMIT)[^\\\"\\n]*\\\")|(?:\\$\\1\\s*\\.\\s*'[^'\\n]*(?:ORDER\\s+BY|LIMIT)[^'\\n]*'))"
    },
    {
      "id": "poc_lfi_template_param_1",
      "category": "LFI",
      "enabled": true,
      "input_pattern": "(?:wp_ajax_nopriv_[A-Za-z0-9_]+|register_rest_route)[^\\n]{0,220}(?:template|file|path|include|instawp-database-manager)",
      "output_pattern": "(?:include|require)(?:_once)?\\s*\\(\\s*(?!(?:realpath|basename|sanitize_file_name|wp_normalize_path)\\s*\\()\\$[A-Za-z_][A-Za-z0-9_]*"
    },
    {
      "id": "poc_open_redirect_1",
      "category": "OpenRedirect",
      "enabled": true,
      "input_pattern": "\\$([A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*(?:sanitize_text_field|wp_unslash)?\\s*\\(?\\s*\\$_(?:GET|POST|REQUEST)\\s*\\[[\\\"'](?:redirect|redirect_to|url|next|target|return)[\\\"']\\]\\s*\\)?",
      "output_pattern": "\\bwp_redirect\\s*\\(\\s*(?!(?:wp_validate_redirect|wp_safe_redirect|esc_url_raw)\\s*\\()\\$\\1\\s*\\)"
    },
    {
      "id": "poc_afu_ajax_upload_1",
      "category": "ArbitraryFileUpload",
      "enabled": true,
      "input_pattern": "(?:wp_ajax_nopriv_[A-Za-z0-9_]*upload|action\\s*=\\s*['\\\"][A-Za-z0-9_]*upload[A-Za-z0-9_]*['\\\"])[^\\n]{0,220}\\$_FILES",
      "output_pattern": "(?:move_uploaded_file|wp_handle_upload|media_handle_upload)\\s*\\([^\\n;]{0,220}(?!(?:wp_check_filetype_and_ext|sanitize_file_name|current_user_can)\\s*\\()"
    },
    {
      "id": "poc_rce_callable_from_input_1",
      "category": "RCE",
      "enabled": true,
      "input_pattern": "\\$([A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*(?:sanitize_text_field|wp_unslash)?\\s*\\(?\\s*\\$_(?:GET|POST|REQUEST|COOKIE)\\s*\\[[^\\]]+\\]\\s*\\)?",
      "output_pattern": "(?:call_user_func_array|call_user_func)\\s*\\(\\s*\\$\\1"
    },
    {
      "id": "poc_auth_bypass_admin_create_1",
      "category": "AuthBypass",
      "enabled": true,
      "input_pattern": "(?:st_authorization|secret_key|authenticate_user|autheticate_user|permission_callback\\s*=>\\s*['\\\"]__return_true['\\\"])",
      "output_pattern": "(?:wp_insert_user|wp_create_user|set_role\\s*\\(\\s*['\\\"]administrator['\\\"]|add_user_to_blog)"
    },
    {
      "id": "poc_xss_echo_unescaped_1",
      "category": "XSS",
      "enabled": true,
      "input_pattern": "\\$([A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*(?:wp_unslash\\s*\\()?\\s*\\$_(?:GET|POST|REQUEST|COOKIE|SERVER)\\s*\\[[^\\]]+\\]\\s*\\)?",
      "output_pattern": "\\b(?:echo|print|printf|die|wp_die)\\b[^\\n;]{0,120}(?!(?:esc_html|esc_attr|esc_url|wp_kses)\\s*\\()\\$\\1"
    },
    {
      "id": "poc_afr_unsafe_read_1",
      "category": "ArbitraryFileRead",
      "enabled": true,
      "input_pattern": "\\$([A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*(?:sanitize_text_field|wp_unslash)?\\s*\\(?\\s*\\$_(?:GET|POST|REQUEST)\\s*\\[[^\\]]+\\]\\s*\\)?",
      "output_pattern": "(?:file_get_contents|readfile|fopen)\\s*\\(\\s*(?!(?:realpath|basename|sanitize_file_name|wp_normalize_path)\\s*\\()\\$\\1"
    },
    {
      "id": "poc_content_injection_rest_1",
      "category": "ContentInjection",
      "enabled": true,
      "input_pattern": "register_rest_route\\s*\\([^\\n;]{0,500}permission_callback\\s*=>\\s*(?:'__return_true'|\\\"__return_true\\\")",
      "output_pattern": "(?:wp_update_post|wp_insert_post|update_post_meta)\\s*\\([^\\n;]{0,260}(?:\\$_(?:POST|REQUEST)|\\$request->get_param)"
    }
  ]
}
